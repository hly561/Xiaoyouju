{
  "pages": [
    "pages/home/index",
    "pages/my/index",
    "pages/my/circles/index",
    "pages/activity-detail/index",
    "pages/activity-detail/questionnaire-detail/index",
    "pages/city-selector/index",
    "pages/message/index",
    "pages/review/index",
    "pages/my/organized-activities/index",
    "pages/my/participated-activities/index",
    "pages/contact-us/index",
    "pages/certification/index",
    "pages/certification/certification-form/index"
  ],
  "useExtendedLib": {
    "weui": true
  },
  "usingComponents": {
    "t-toast": "tdesign-miniprogram/toast/toast"
  },

  "permission": {
    "scope.userLocation": {
      "desc": "你的位置信息将用于小程序定位"
    },
    "scope.userFuzzyLocation": {
      "desc": "你的位置信息将用于小程序定位"
    }
  },
  "requiredPrivateInfos": [
    "getFuzzyLocation",
    "chooseLocation"
  ],
  "requiredBackgroundModes": [
    "location"
  ],
  "subpackages": [
    {
      "root": "pages/search",
      "name": "search",
      "pages": ["index"]
    },
    {
      "root": "pages/my/info-edit",
      "name": "edit",
      "pages": ["index"]
    },
    {
      "root": "pages/chat",
      "name": "chat",
      "pages": ["index"]
    },
    {
      "root": "pages/login",
      "name": "login",
      "pages": ["login"]
    },
    {
      "root": "pages/school-selector",
      "name": "school",
      "pages": ["index"]
    },
    {
      "root": "pages/dataCenter",
      "name": "dataCenter",
      "pages": ["index"]
    },
    {
      "root": "pages/release",
      "name": "release",
      "pages": ["index", "questionnaire/index"]
    },
    {
      "root": "pages/my/verify",
      "name": "verify",
      "pages": ["index"]
    },
    {
      "root": "pages/interests",
      "name": "interests",
      "pages": ["index"]
    }
    
  ],
  "window": {
    "backgroundTextStyle": "light",
    "navigationBarBackgroundColor": "#fff",
    "navigationBarTitleText": "WeChat",
    "navigationBarTextStyle": "black",
    "disableSwipeBack": true
  },
  "tabBar": {
    "custom": true,
    "list": [
      {
        "pagePath": "pages/home/index",
        "text": "首页"
      },
      {
        "pagePath": "pages/message/index",
        "text": "消息"
      },
      {
        "pagePath": "pages/my/index",
        "text": "我的"
      }
    ]
  },
  "resolveAlias": {
    "~/*": "/*"
  },
  "style": "v2",
  "sitemapLocation": "sitemap.json",
  "lazyCodeLoading": "requiredComponents"
}
