.activity-detail {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  overflow-y: auto;
  background-color: #f8f8f8;
}

.activity-detail-container {
  padding: 20rpx;
  background-color: #f8f8f8;
  padding-bottom: 160rpx;
}

.activity-header {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx 20rpx 1rpx 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.activity-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  margin-top: 20rpx;
  word-break: break-word;
  overflow-wrap: anywhere;
}

.activity-info {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
  margin-top: 20rpx;
}

.activity-info text {
  display: block;
  margin-bottom: 10rpx;
}

.activity-description {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 20rpx;
  white-space: pre-wrap;
  word-wrap: break-word;
}

.activity-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #666;
  margin: 1rpx 0;
}

.activity-footer text {
  display: block;
  margin: 1rpx 0;
}

.qr-code {
  width: 200rpx;
  height: 200rpx;
  margin-top: 20rpx;
}

/* 删除旧的顶部报名容器样式，统一使用 register-footer */

.creator-buttons {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 90%;
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  z-index: 1000;
}

.creator-button {
  flex: 1;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  border-radius: 10rpx;
  font-size: 36rpx;
  font-weight: bold;
  display: flex;
  justify-content: center;
  align-items: center;
}

.edit-button {
  background-color: #1a73e8;
  color: #fff;
}

.delete-button {
  background-color: #e53e3e;
  color: #fff;
}

.registered-users {
  margin-top: 20rpx;
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.organizer-card {
  margin-top: 20rpx;
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.section-link {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.section-link-text {
  color: #666;
}

.section-title-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.participants-count {
  font-size: 28rpx;
  font-weight: normal;
  color: #666;
}

.registered-option {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 16rpx;
  padding: 0 0 8rpx 0;
  margin-top: -12rpx;
  margin-bottom: 16rpx;
}
.registered-option-label { color: #666; font-size: 26rpx; }
.registered-option-group { display: flex; align-items: center; gap: 16rpx; }

.user-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.user-item {
  margin-right: 20rpx;
  margin-bottom: 10rpx;
  font-size: 28rpx;
  color: #666;
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 10rpx;
  /* 防止在长文本挤压时头像被压缩 */
  flex-shrink: 0;
}

.user-avatar.default-avatar {
  background-color: #e3f2fd;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  color: #1976d2;
  font-size: 32rpx;
  font-weight: bold;
}

.user-info {
  display: flex;
  flex-direction: column;
  /* 占据剩余空间以便内部文本正常换行 */
  flex: 1;
  min-width: 0;
}

.user-nickname {
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx; /* 调小与教育信息的距离 */
}

.user-school, .user-major, .user-graduation {
  font-size: 24rpx;
  color: #999;
  line-height: 1.25;
}

.user-school-major {
  font-size: 24rpx;
  color: #999;
  display: inline; /* 与后续文本保持同一行 */
  /* 允许长英文/专业名称换行，不溢出 */
  word-break: break-all;
  white-space: normal;
  min-width: 0;
  line-height: 1.25;
}

/* 多条教育信息展示 */
.user-educations {
  display: flex;
  flex-direction: column;
}

.education-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  line-height: 1.25;
  margin-bottom: 4rpx;
}

.education-text {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 4rpx;
  flex: 1;
  min-width: 0;
}

.user-messages { margin-top: 12rpx; display: flex; flex-direction: column; gap: 8rpx; }
.user-message { display: block; }
.user-message-bubble { display: flex; align-items: flex-start; gap: 8rpx; background: #f7f7f7; padding: 12rpx; border-radius: 8rpx; }
.user-message-label { flex: 0 0 auto; color: #666; font-size: 26rpx; line-height: 1.5; }
.user-message-content { flex: 1 1 auto; font-size: 26rpx; color: #333; word-break: break-word; overflow-wrap: anywhere; }

.edu-eye {
  flex-shrink: 0;
  margin-left: 12rpx;
}

.user-degree {
  font-size: 24rpx;
  color: #999;
  display: inline; /* 显式为内联，紧跟专业 */
  line-height: 1.25;
}

.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}


.info-item t-icon {
  margin-right: 80rpx;
  flex-shrink: 0;
}

.info-item text {
  line-height: 1.5;
  padding-left: 20rpx;
  padding-top: 8rpx;
}

.deadline-status.expired {
  color: #ff4757;
  font-weight: bold;
}

.qrcode-section {
  margin-top: 20rpx;
}

.qrcode-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
}

.qrcode-error {
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  border: 1rpx dashed #ccc;
  border-radius: 8rpx;
  color: #999;
  font-size: 24rpx;
  text-align: center;
}
.org-education-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  line-height: 1.25;
  margin-bottom: 4rpx;
}

.org-education-text {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 4rpx;
  flex: 1;
  min-width: 0;
}
.qn-fill-container { background:#fff; border-radius:16rpx 16rpx 0 0; padding:24rpx; }
.qn-fill-header { font-size:32rpx; font-weight:500; margin-bottom:16rpx; }
.qn-fill-body { height:60vh; overflow:hidden; }
.qn-fill-item { margin-bottom:16rpx; }
.qn-field-title { font-size:28rpx; color:#333; margin-bottom:8rpx; }
.qn-type-tag { font-size:24rpx; color:#999; margin-left:8rpx; }
.qn-field-desc { font-size:24rpx; color:#999; margin-top:4rpx; }
.req-star { color:#FF3B30; margin-left:8rpx; }
.qn-fill-footer { display:flex; gap:16rpx; padding-top:12rpx; }
.qn-submit { flex:1; }
.qn-cancel { flex:1; }
.leave-popup { background:#fff; border-radius:16rpx 16rpx 0 0; padding:24rpx; }
.leave-header { font-size:32rpx; font-weight:500; margin-bottom:16rpx; color:#333; }
.leave-body { margin-bottom:16rpx; }
.leave-footer { display:flex; gap:16rpx; }
.leave-cancel { flex:1; }
.leave-submit { flex:1; }
.register-footer {
  position: fixed;
  left: 50%;
  transform: translateX(-50%);
  bottom: 40rpx;
  width: 90%;
  z-index: 10000;
  box-sizing: border-box;
}

.register-footer-row { display: flex; gap: 16rpx; }
.register-footer-row .register-button-native { flex: 1; }

button.register-button-native {
  width: 100% !important;
  min-height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  border-radius: 10rpx;
  border: none;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  background-color: #1a73e8;
  display: block;
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

button.register-button-native::after {
  border: none;
}

button.register-button-native.primary { background-color: #1a73e8 !important; }
button.register-button-native.danger { background-color: #e53e3e !important; }
button.register-button-native[disabled] { background-color: #e0e0e0 !important; color: #999 !important; }
.poster-gallery {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.poster-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
}