.qn-detail-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.state-text {
  text-align: center;
  color: #999;
  margin-top: 80rpx;
}

.participant-list {
  flex: 1;
}

.participant-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}
.participant-card:last-child { margin-bottom: 0; }
.participant-list .participant-card:last-of-type { margin-bottom: 0; }

.participant-top {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.participant-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 24rpx;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.participant-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  font-size: 32rpx;
  color: #1a73e8;
  font-weight: bold;
}

.participant-info {
  flex: 1;
}

.participant-nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.participant-time {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 6rpx;
}

.participant-time {
  color: #999;
}

.field-list {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 16rpx;
}

.field-item {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f7f7f7;
}

.field-item:last-of-type {
  border-bottom: none;
}

.field-title {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 6rpx;
}

.field-value {
  font-size: 28rpx;
  color: #333;
  word-break: break-all;
}

