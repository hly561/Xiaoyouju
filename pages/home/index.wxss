.home-container {
  height: calc(100vh - 112rpx);
}

.home-container .home-content {
  height: calc(100% - 60px);
  margin-top: 20rpx;
}

.home-container .t-tabs {
  --td-tab-item-tag-height: 96rpx;
  --td-tab-font-size: 16px;
  width: 100%;
  height: 100%;
}

.home-container .t-tabs__content {
  height: calc(100% - 96rpx);
  overflow: auto;
  background-color: #f3f3f3;
}

.home-container .subcategory-container {
  background-color: #fff;
  padding: 0;
  position: relative;
  border-bottom: 1rpx solid #f5f5f5;
}

.home-container .subcategory-scroll-container {
  position: relative;
  padding-right: 60rpx;
}

.home-container .subcategory-scroll {
  width: 100%;
  white-space: nowrap;
  height: 80rpx;
  padding: 0 24rpx;
}

.home-container .subcategory-list {
  display: inline-flex;
  padding: 16rpx 0;
}

.home-container .subcategory-item {
  display: inline-flex;
  align-items: center;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: rgba(51, 51, 51, 0.63);
  position: relative;
  height: 48rpx;
  font-weight: 400;
}

.home-container .subcategory-item--active {
  color: #000000;
  font-weight: 400;
}

.home-container .subcategory-arrow {
  position: absolute;
  right: 0;
  top: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 80rpx;
  z-index: 1;
  background: linear-gradient(to right, rgba(255, 255, 255, 0), #ffffff 40%);
}

.home-container .home-card-list {
  display: flex;
  gap: 24rpx 12rpx;
  padding: 24rpx;
  background-color: #f3f3f3;
  padding-bottom: 240rpx;
}

.activity-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.06);
  display: flex !important;
  flex-direction: row !important;
  align-items: center !important;
  justify-content: space-between !important;
  position: relative !important;
}

.card-left { flex: 1; min-width: 0; padding-right: 120rpx; }
.poster-thumb { width: 96rpx !important; height: 96rpx !important; border-radius: 12rpx; background-color: #f5f5f5; flex-shrink: 0; margin-left: 12rpx; position: absolute !important; right: 24rpx !important; top: 24rpx !important; }
.activity-card { gap: 12rpx; align-items: center; }
.card-left { max-width: calc(100% - 108rpx); }

.home-release {
  position: fixed;
  bottom: 208rpx;
  right: 32rpx;
  z-index: 100;
}

.home-release .small-release-button {
  width: 200rpx !important;
}

/* 筛选标签样式 */
.filter-container {
  background-color: #fff;
  border-bottom: 1rpx solid #e7e7e7;
  padding: 0;
}

.filter-scroll {
  width: 100%;
  white-space: nowrap;
  height: 80rpx;
}

.filter-tags {
  display: inline-flex;
  padding: 12rpx 24rpx;
  gap: 16rpx;
  align-items: center;
  height: 100%;
}

.filter-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 400;
  color: #00000099;
  background-color: #f3f3f3;
  border: none;
  white-space: nowrap;
  transition: all 0.15s ease;
  min-width: 72rpx;
  height: 48rpx;
  box-sizing: border-box;
}

.filter-tag.active {
  color: #fff;
  background-color: #0052d9;
  font-weight: 500;
}

.filter-tag:active {
  transform: scale(0.98);
  opacity: 0.8;
}

.filter-tag.subcategory-tag {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  height: 40rpx;
  background-color: #f3f3f3;
  border-radius: 20rpx;
  color: #00000066;
}

.filter-tag.subcategory-tag.active {
  background-color: #0052d9;
  color: #fff;
  font-weight: 500;
}

.subcategory-tags {
  padding: 8rpx 24rpx 12rpx 24rpx;
  gap: 12rpx;
}

.interest-guide {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 90%;
  margin: 30rpx auto;
  padding: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.3);
  text-align: center;
}

.interest-guide text {
  font-size: 28rpx;
  color: #ffffff;
  margin-bottom: 30rpx;
  line-height: 1.5;
  font-weight: 500;
}

.interest-btn {
  width: 240rpx;
  height: 80rpx;
  background: #ffffff;
  color: #667eea;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 255, 255, 0.3);
}

.interest-btn:active {
  opacity: 0.8;
}
.activity-title { font-size: 28rpx; font-weight: 600; color: #333; word-break: break-word; overflow-wrap: anywhere; }