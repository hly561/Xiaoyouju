page {
  background-color: #f7f8fa;
  min-height: 100vh;
  padding: 30rpx 0 40rpx;
}

.interest-tip {
  background-color: #fff;
  padding: 30rpx;
  margin: 0 30rpx 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.interest-form {
  margin: 0 30rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.category-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 30rpx;
  color: #333;
  position: relative;
  padding-left: 24rpx;
  display: flex;
  align-items: center;
}

.category-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 36rpx;
  background: linear-gradient(to bottom, #0052d9, #2b85e4);
  border-radius: 4rpx;
}

.options-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.option-tag {
  padding: 12rpx 24rpx;
  border: 1rpx solid #eee;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #f8f8f8;
  transition: all 0.3s ease;
}

.option-tag.selected {
  background-color: #1a73e8 !important;
  color: #fff !important;
  border-color: #1a73e8 !important;
  box-shadow: 0 4rpx 8rpx rgba(26, 115, 232, 0.2);
}

.option-tag:active {
  transform: scale(0.95);
}

.footer-btn-bar {
  margin: 60rpx 30rpx 0;
  padding: 0;
  background: transparent;
  box-shadow: none;
  position: static;
}

.confirm-btn {
  width: 100%;
  height: 96rpx;
  font-size: 32rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #0052d9, #2b85e4);
  color: #fff;
  font-weight: 600;
  letter-spacing: 4rpx;
  text-align: center;
  line-height: 96rpx;
  box-shadow: 0 8rpx 16rpx rgba(0, 82, 217, 0.2);
  transition: all 0.3s ease;
}

.confirm-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 8rpx rgba(0, 82, 217, 0.2);
}

/* 分类区域 */
.category-sections {
  padding: 0 30rpx;
}

.category-section {
  margin-bottom: 40rpx;
}

.category-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  position: relative;
}

.category-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 24rpx;
  background: linear-gradient(135deg, #0052d9, #2b85e4);
  border-radius: 3rpx;
}

.sub-category-list {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
  background: transparent;
}

.sub-category-item {
  padding: 14rpx 28rpx;
  border-radius: 36rpx;
  background: #e8ecf0;
  color: #333;
  font-size: 26rpx;
  transition: all 0.3s ease;
  margin: 0 16rpx 16rpx 0;
  display: inline-block;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.sub-category-item.selected {
  background: linear-gradient(135deg, #0052d9, #2b85e4);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 82, 217, 0.3);
  transform: translateY(-2rpx);
}