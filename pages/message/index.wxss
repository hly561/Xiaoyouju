.page {
  height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  padding-top: 20rpx;
  padding-bottom: 120rpx;
}

/* 加载状态 */
.loading-container {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 999;
}

/* 空状态 */
.empty-container {
  position: absolute;
  top: 45%;
  left: 0;
  right: 0;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #999;
}

/* 消息列表 */
.message-container {
  background-color: #f5f5f5;
  padding: 16rpx 16rpx 190rpx 16rpx;
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.message-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  margin: 0 20rpx 16rpx 20rpx;
  border-radius: 16rpx;
  background-color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s;
  position: relative;
  z-index: 2;
}



.message-item:active {
  background-color: #f8f8f8;
  transform: scale(0.98);
}



.message-avatar {
  width: 80rpx;
  height: 80rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background-color: #e3f2fd;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 0;
}

.avatar-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #e3f2fd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

/* t-icon 组件样式调整 */
.message-avatar .avatar-icon {
  background-color: transparent !important;
  border-radius: 0 !important;
  margin: 0 !important;
  padding: 0 !important;
  line-height: 1 !important;
}

.message-content {
  flex: 1;
  position: relative;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.message-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
}

.message-time {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}

.message-time {
  font-size: 24rpx;
  color: #999;
}

.message-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.4;
  word-wrap: break-word;
  word-break: break-all;
}



.message-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  flex-shrink: 0;
}

/* 未读消息红点 */
.message-unread-dot {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 16rpx;
  height: 16rpx;
  background-color: #ff4757;
  border-radius: 50%;
  z-index: 10;
}




/* 箭头上方的红点 */
.arrow-unread-dot {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 16rpx;
  height: 16rpx;
  background-color: #ff4757;
  border-radius: 50%;
  z-index: 10;
}

/* 不可跳转消息的红点 */
.no-arrow-unread-dot {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 16rpx;
  height: 16rpx;
  background-color: #ff4757;
  border-radius: 50%;
  z-index: 10;
}

/* 自定义滑动条样式 */
.custom-scroll {
  /* 滑动条往右移动，避免与卡片重叠 */
  padding-right: 10rpx;
}

/* 自定义导航栏样式 */

.login-guide-btn {
  width: 80vw;
  max-width: 460rpx;
  height: 88rpx;
  margin: 24rpx auto 0 auto;
  border: none;
  border-radius: 44rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  background: linear-gradient(90deg, #1677ff 0%, #49b1f5 100%);
  box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0;
}
.login-guide-btn:active {
  opacity: 0.92;
  box-shadow: 0 4rpx 12rpx rgba(22, 119, 255, 0.18);
}