<t-toast id="t-toast" />

<view class="my">
  <image class="nav-bg" src="/static/bg_navbar.png" />
  <nav title-text="我的" top-extra="{{34}}" />
  <view class="my-info">
    <t-cell-group>
      <t-cell wx:if="{{isLoad}}" bordered="{{false}}" t-class-center="cell-class-center">
        <t-avatar image="{{personalInfo.image}}" slot="left-icon" size="large" />
        <view class="my-info__person" slot="description">
          <view class="name">{{personalInfo.name}}</view>
          
        </view>
        <t-icon slot="right-icon" name="edit" size="40rpx" color="#000000e6" bindtap="onNavigateTo" />
      </t-cell>
      <t-cell
        wx:if="{{!isLoad}}"
        title="请先登录/注册"
        bordered="{{false}}"
        t-class-title="cell-class-title"
        t-class-center="cell-class-center"
        bindtap="onLogin"
      >
        <t-avatar slot="left-icon" icon="user" size="128rpx" />
      </t-cell>
    </t-cell-group>
    <t-divider t-class="divider-class" />
    <t-grid t-class="grid-class">
      <t-grid-item
        wx:for="{{gridList}}"
        wx:for-item="gridItem"
        wx:key="type"
        text="{{gridItem.name}}"
        icon="{{gridItem.icon}}"
        class="grid-item {{gridItem.type === 'all' ? 'split-line' : ''}}"
        data-data="{{gridItem}}"
        bindclick="onEleClick"
      />
    </t-grid>
  </view>

  <!-- 审核中心单独卡片 -->
  <view wx:if="{{personalInfo.role === 'school_manager' || personalInfo.role === 'general_manager'}}" style="margin-top: 24rpx; padding: 0 32rpx;">
    <view style="border-radius: 20rpx; overflow: hidden; box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06); background: #fff;">
      <t-cell
        title="审核中心"
        leftIcon="check-circle"
        hover
        arrow
        bordered
        data-data="{{ { name: '审核中心', icon: 'check-circle', type: 'review', url: '/pages/review/index' } }}"
        bindclick="onEleClick"
      >
        <view slot="right-icon" wx:if="{{pendingCount > 0}}" class="pending-dot">
          <text>{{pendingCount > 99 ? '···' : pendingCount}}</text>
        </view>
      </t-cell>
    </view>
  </view>

  <!-- 校友认证+我的兴趣+联系客服+退出登录 合并卡片 -->
  <view style="margin-top: 24rpx; padding: 0 32rpx;">
    <view style="border-radius: 20rpx; overflow: hidden; box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06); background: #fff;">
      <t-cell
        title="校友认证"
        leftIcon="verified"
        hover
        arrow
        bordered
        data-data="{{ { name: '校友认证', icon: 'verified', type: 'verify' } }}"
        bindclick="onEleClick"
      />
      <t-cell
        wx:for="{{settingList}}"
        wx:for-item="item"
        wx:key="type"
        wx:if="{{item.type === 'interests' || item.type === 'contact' || item.type === 'logout'}}"
        title="{{item.name}}"
        leftIcon="{{item.icon}}"
        hover
        arrow
        data-data="{{item}}"
        bindclick="onEleClick"
      />
    </view>
  </view>
</view>
<!-- 移除未使用的 WXS 模块，避免编译错误 -->
