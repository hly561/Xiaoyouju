.my-info {
  background-color: #fff;
}

.my-info__person {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.auth-status {
  font-size: 24rpx;
  color: #666;
  padding: 4rpx 12rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  display: inline-block;
}

.setting-group {
  margin-top: 120rpx;
}

.setting-group t-cell,
.setting-group t-cell-group {
  border-radius: 20rpx;
  overflow: hidden;
}

.pending-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 36rpx;
  height: 36rpx;
  background: #f44;
  color: #fff;
  border-radius: 18rpx;
  font-size: 26rpx;
  font-weight: bold;
  margin-left: 16rpx;
  padding: 0 10rpx;
}