.organized-activities {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

.empty-container {
  padding: 120rpx 32rpx;
}

.activities-container {
  padding: 24rpx 32rpx;
}

.activity-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.activity-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.activity-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  flex: 1;
  margin-right: 24rpx;
}

.activity-actions {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.activity-info {
  margin-bottom: 24rpx;
}

.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  color: #666;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-item .t-icon {
  margin-right: 12rpx;
}

.activity-status {
  display: flex;
  align-items: center;
}

.status-tag {
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
  border: 1rpx solid;
  white-space: nowrap;
}

.registration-tag {
  margin-right: 12rpx;
}

.participant-count {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.count-number {
  font-size: 32rpx;
  font-weight: 600;
  color: #0052d9;
}

.count-text {
  font-size: 24rpx;
  color: #999;
}