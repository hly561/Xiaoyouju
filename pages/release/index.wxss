/* 活动类型标签样式 */
.t-radio.activity-type-tag {
  margin: 0 !important; /* 移除默认外边距 */
  padding: 12rpx 24rpx !important; /* 调整内边距为更明显的胶囊样式 */
  background-color: #f5f5f5 !important; /* 未选中背景色 */
  border-radius: 9999rpx !important; /* 胶囊圆角 */
  border: none !important; /* 移除边框 */
}

.t-radio.activity-type-tag.t-is-checked {
  background-color: #0052d9 !important; /* 选中背景色 */
}

.t-radio .activity-type-tag-label,
.t-radio.activity-type-tag .t-radio__label {
  color: #666666 !important; /* 未选中文字颜色 */
  font-size: 26rpx !important; /* 文字大小 */
  line-height: 1 !important; /* 紧凑行高 */
}

.t-radio.activity-type-tag.t-is-checked .activity-type-tag-label,
.t-radio.activity-type-tag.t-is-checked .t-radio__label {
  color: #ffffff !important; /* 选中文字颜色 */
}

/* 活动类型容器样式 */
.activity-category-container {
  padding: 5rpx 32rpx 16rpx 32rpx;
  background-color: #fff;
  margin-bottom: 0;
  border-bottom: none;
}

.activity-category-container .t-radio-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  width: 100%;
}

/* 隐藏单选按钮的图标 */
.t-radio.activity-type-tag .t-radio__icon,
.t-radio.activity-type-tag .t-radio__border {
  display: none !important;
}

/* 调整单选按钮的内部布局 */
.t-radio.activity-type-tag .t-radio__content {
  padding-left: 0 !important;
  margin-left: 0 !important;
}

/* 分隔线样式 */
.separator-line {
  display: block;
  width: 100%;
  height: 0;
  border-top: 1px solid #e5e5e5;
  margin: 16rpx 0;
}

