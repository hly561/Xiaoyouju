.page {
  padding: 0 32rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
  background-color: #f5f5f5;
}
.qn-container {
  margin-top: 20rpx;
}
.qn-meta {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #e6e6e6;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
  margin-bottom: 24rpx;
}
.qn-meta-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0;
}
.qn-meta-label { color: #333; font-size: 28rpx; }
.qn-header {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  margin-bottom: 16rpx;
}
.qn-summary { margin-left: auto; }
.qn-header .t-button { margin-left: 0 !important; }
.qn-summary {
  color: #666;
  font-size: 24rpx;
}
.qn-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #e6e6e6;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
  overflow: hidden;
}
.qn-top-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.qn-num { display: flex; align-items: center; gap: 8rpx; }
.qn-top-row .t-input { flex: 1; margin: 0; min-width: 0; }
.qn-required-inline { display: flex; align-items: center; gap: 12rpx; color: #666; }
.qn-card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.req-star {
  color: #FF3B30;
}
.qn-number {
  font-size: 28rpx;
  color: #333;
}
.qn-type-row { margin: 8rpx 0 12rpx 0; }
.qn-card .t-input { width: 100%; margin: 8rpx 0; }
.qn-card .t-input,
.qn-card .t-input__wrapper,
.qn-card .t-input__content { width: 100% !important; max-width: 100% !important; box-sizing: border-box !important; }
.qn-card .t-input__content { padding-right: 0 !important; }
.qn-type-row .t-radio-group { display: flex !important; flex-direction: row !important; gap: 24rpx !important; width: auto !important; }
.qn-type-row .t-radio { width: auto !important; margin: 0 !important; }
.qn-cell {
  margin-bottom: 16rpx;
}
.option-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 16rpx 0;
}
.qn-option-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
  background-color: #fafafa;
  border: 1rpx solid #e7e7e7;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}
.opt-letter {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  background-color: #f0f3ff;
  color: #0052d9;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.qn-option-input {
  flex: 1;
}
.qn-card-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding-top: 12rpx;
}
.qn-card-actions.single { justify-content: flex-end; width: 100%; }
.qn-card-actions .t-button { min-width: 160rpx; }
.qn-card-actions .action-btn { flex: 1 1 0 !important; width: auto !important; min-width: 0 !important; }
.qn-card-actions.single .action-btn { flex: 0 0 160rpx !important; }
.qn-card-actions.single .action-btn { margin-left: auto !important; margin-right: 0 !important; }
.qn-card-actions.single .qn-delete-btn { margin-left: auto !important; }
.qn-card-actions.single .t-button { margin-left: auto !important; margin-right: 0 !important; }
.qn-option-del {
  margin-left: auto;
  min-width: 100rpx !important;
  width: auto !important;
  padding: 8rpx 16rpx !important;
  font-size: 22rpx !important;
  line-height: 1 !important;
}
.action-item { color: #666; }
.action-divider { width: 1rpx; height: 28rpx; background: #e6e6e6; }
.del-btn {
  margin-top: 8rpx;
}
.qn-actions {
  margin-top: 24rpx;
}

.qn-footer {
  margin: 16rpx -32rpx 16rpx;
  padding: 0 32rpx;
}
.qn-footer .t-button {
  width: 100% !important;
}

.qn-after-footer-spacer {
  height: calc(env(safe-area-inset-bottom) + 24rpx);
}