.review-container {
  padding: 32rpx 24rpx;
}
.review-title-row { display:flex; align-items:center; justify-content:space-between; margin-bottom: 32rpx; }
.review-title { font-size: 36rpx; font-weight: bold; }
.mgr-icon { color:#666; padding: 8rpx 12rpx; border-radius: 9999rpx; background:#f3f3f3; }
.user-card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
  margin-bottom: 32rpx;
  padding: 24rpx;
}
.user-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background: #e3f2fd;
}
.user-info {
  display: flex;
  flex-direction: column;
}
.user-name {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}
.user-phone {
  font-size: 28rpx;
  color: #888;
}
.user-detail {
  font-size: 28rpx;
  color: #333;
  line-height: 2;
}
.verify-img {
  width: 240rpx;
  height: 180rpx;
  margin-top: 8rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}
.empty-tip {
  color: #aaa;
  text-align: center;
  margin: 64rpx 0;
  font-size: 30rpx;
}
.review-actions {
  display: flex;
  gap: 32rpx;
  margin-top: 24rpx;
  flex-direction: row;
}
.reject-btn {
  flex: 1;
  background: #e5e5e5;
  color: #666;
  border: none;
  border-radius: 12rpx;
  font-size: 30rpx;
  padding: 16rpx 0;
  order: 1;
}
.approve-btn {
  flex: 1;
  background: #1a73e8;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 30rpx;
  padding: 16rpx 0;
  order: 2;
}

/* 自定义学校标注样式 */
.school-info {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.custom-school-tag {
  background-color: #1a73e8;
  border-radius: 6rpx;
  padding: 8rpx;
  margin-left: 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.tag-text {
  color: #fff;
  font-size: 18rpx;
  font-weight: bold;
  line-height: 1;
}

.custom-school-detail {
  font-size: 28rpx;
  color: #333;
  line-height: 2;
}

/* 管理学校弹层 */
.mgr-mask { position: fixed; left:0; top:0; right:0; bottom:0; background: rgba(0,0,0,0.35); z-index: 1000; }
.mgr-panel { position: fixed; left: 48rpx; right: 48rpx; top: 20%; background:#fff; border-radius: 16rpx; box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.12); z-index: 1001; display:flex; flex-direction:column; }
.mgr-header { display:flex; align-items:center; justify-content:space-between; padding: 24rpx; border-bottom: 1rpx solid #f0f0f0; }
.mgr-title { font-size: 32rpx; font-weight: 600; color:#333; }
.mgr-close { color:#999; padding: 8rpx 12rpx; display:flex; align-items:center; }
.mgr-body { padding: 16rpx 24rpx 24rpx; max-height: 50vh; overflow:auto; }
.mgr-item { padding: 16rpx 0; border-bottom: 1rpx dashed #eee; font-size: 28rpx; color:#333; }
.mgr-item:last-child { border-bottom: none; }
.mgr-empty { padding: 24rpx; text-align:center; color:#999; font-size: 28rpx; }
